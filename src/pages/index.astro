---
import Layout from "@/layouts/Layout.astro";
import ToolDirectory from "@/components/ToolDirectory";

// Dynamically scan the tools folder for all .astro files
const toolFiles = import.meta.glob("./tools/*.astro", { eager: true });

// Extract the metadata from each file and build the array automatically
const dynamicTools = Object.entries(toolFiles)
	.map(([filePath, module]: any) => {
		// If a file doesn't have toolMeta exported, we skip it
		if (!module.toolMeta) return null;

		// Automatically format the path
		const path = filePath.replace(".", "").replace(".astro", "");

		return {
			...module.toolMeta,
			path,
		};
	})
	.filter(Boolean);
---

<Layout
	title="Axiora Tools | Premium Utilities for Modern Workflows"
	description="A fast, lightweight collection of premium utility tools. Process text, generate passwords, and format code instantly in your browser with zero tracking."
>
	{/* The Dynamic React Component (Contains Hero & Grid) */}
	<ToolDirectory tools={dynamicTools} client:load />

	{/* Premium SaaS Value Proposition Section */}
	<section
		class="w-full relative z-10 mt-32 pt-24 pb-16 relative overflow-hidden"
	>
		{/* Ambient Background Glow for the section */}
		<div
			class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-4xl h-[400px] bg-primary/[0.03] blur-[100px] rounded-full pointer-events-none -z-10"
		>
		</div>

		<div class="container mx-auto px-6 md:px-12 max-w-7xl relative z-10">
			<div class="text-center max-w-3xl mx-auto mb-20">
				<h2
					class="text-4xl md:text-5xl font-extrabold tracking-tight mb-6"
				>
					Engineered for absolute <span class="text-gradient"
						>privacy & speed.</span
					>
				</h2>
				<p
					class="text-lg md:text-xl text-foreground/60 font-medium leading-relaxed"
				>
					We believe premium tools shouldn't compromise your data.
					Every utility executes completely on your device using
					native browser technologies.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10">
				{/* Feature 1: Local Execution */}
				<div
					class="group glass-card rounded-[2rem] p-10 saas-shadow hover:saas-shadow-hover transition-all duration-500 hover:-translate-y-2 relative overflow-hidden"
				>
					{/* Corner ambient glow */}
					<div
						class="absolute -right-10 -top-10 w-32 h-32 bg-primary/10 blur-3xl rounded-full group-hover:bg-primary/20 transition-colors duration-500"
					>
					</div>

					{/* Floating Icon Box */}
					<div
						class="w-16 h-16 rounded-[1.25rem] bg-white border border-border flex items-center justify-center mb-8 saas-shadow relative z-10"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="28"
							height="28"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							class="text-primary"
							><rect
								width="18"
								height="11"
								x="3"
								y="11"
								rx="2"
								ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"
							></path></svg
						>
					</div>

					<h3
						class="text-2xl font-bold text-foreground mb-4 tracking-tight relative z-10"
					>
						100% Local Execution
					</h3>
					<p
						class="text-foreground/60 font-medium leading-relaxed relative z-10"
					>
						Your data never leaves your device. Cryptographic
						functions, formatting, and analysis happen directly in
						your browser's memory. No backend servers involved.
					</p>
				</div>

				{/* Feature 2: Zero Latency */}
				<div
					class="group glass-card rounded-[2rem] p-10 saas-shadow hover:saas-shadow-hover transition-all duration-500 hover:-translate-y-2 relative overflow-hidden"
				>
					{/* Corner ambient glow */}
					<div
						class="absolute -right-10 -top-10 w-32 h-32 bg-secondary/10 blur-3xl rounded-full group-hover:bg-secondary/20 transition-colors duration-500"
					>
					</div>

					{/* Floating Icon Box */}
					<div
						class="w-16 h-16 rounded-[1.25rem] bg-white border border-border flex items-center justify-center mb-8 saas-shadow relative z-10"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="28"
							height="28"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							class="text-secondary"
							><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"
							></path></svg
						>
					</div>

					<h3
						class="text-2xl font-bold text-foreground mb-4 tracking-tight relative z-10"
					>
						Zero Latency
					</h3>
					<p
						class="text-foreground/60 font-medium leading-relaxed relative z-10"
					>
						No API calls. No loading spinners. Because calculations
						are processed locally, you get instant, real-time
						results as fast as you can type.
					</p>
				</div>

				{/* Feature 3: Distraction Free */}
				<div
					class="group glass-card rounded-[2rem] p-10 saas-shadow hover:saas-shadow-hover transition-all duration-500 hover:-translate-y-2 relative overflow-hidden"
				>
					{/* Corner ambient glow */}
					<div
						class="absolute -right-10 -top-10 w-32 h-32 bg-accent/10 blur-3xl rounded-full group-hover:bg-accent/20 transition-colors duration-500"
					>
					</div>

					{/* Floating Icon Box */}
					<div
						class="w-16 h-16 rounded-[1.25rem] bg-white border border-border flex items-center justify-center mb-8 saas-shadow relative z-10"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="28"
							height="28"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							class="text-accent"
							><circle cx="12" cy="12" r="10"></circle><path
								d="m4.9 4.9 14.2 14.2"></path></svg
						>
					</div>

					<h3
						class="text-2xl font-bold text-foreground mb-4 tracking-tight relative z-10"
					>
						No Ads. No Tracking.
					</h3>
					<p
						class="text-foreground/60 font-medium leading-relaxed relative z-10"
					>
						We designed a pure, distraction-free environment for
						deep work. There are no paywalls, no required sign-ups,
						and absolutely zero intrusive advertisements.
					</p>
				</div>
			</div>
		</div>
	</section>

	{/* Massive SaaS Bottom CTA Banner (Inspired by Fizens) */}
	<section class="w-full px-6 md:px-12 py-16 relative z-10 max-w-7xl mx-auto">
		<div
			class="bg-gradient-saas rounded-[2.5rem] p-10 md:p-16 lg:p-20 flex flex-col md:flex-row items-center justify-between gap-10 saas-glow overflow-hidden relative"
		>
			{/* Inner Decorative Background Elements */}
			<div
				class="absolute -top-32 -right-32 w-80 h-80 bg-white/10 rounded-full blur-3xl"
			>
			</div>
			<div
				class="absolute -bottom-32 -left-32 w-80 h-80 bg-black/10 rounded-full blur-3xl"
			>
			</div>

			<div class="relative z-10 max-w-2xl text-center md:text-left">
				<h2
					class="text-3xl md:text-5xl font-extrabold text-white mb-6 tracking-tight leading-tight"
				>
					Ready to transform your workflow?
				</h2>
				<p
					class="text-white/80 text-lg md:text-xl font-medium leading-relaxed"
				>
					Join thousands of modern professionals who rely on Axiora
					Tools for secure, instant, and beautiful everyday utilities.
				</p>
			</div>

			<div class="relative z-10 flex-shrink-0">
				<a
					href="#"
					class="inline-flex items-center gap-3 bg-white text-primary hover:bg-muted font-bold text-lg px-8 py-5 rounded-full transition-all duration-300 hover:scale-105 saas-shadow group"
				>
					Explore Tools
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="20"
						height="20"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2.5"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="group-hover:-translate-y-1 transition-transform duration-300"
						><path d="m5 12 7-7 7 7"></path><path d="M12 19V5"
						></path></svg
					>
				</a>
			</div>
		</div>
	</section>
</Layout>
