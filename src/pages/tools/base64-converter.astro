---
import Layout from "@/layouts/Layout.astro";
import Base64ConverterComponent from "@/components/tools/Base64Converter.tsx";

// MAGIC: Automatically adds this to the homepage directory
export const toolMeta = {
    id: "base64-conv",
    name: "Base64 Converter",
    desc: "Securely encode or decode strings to and from Base64 format locally in your browser.",
    category: "Developer",
    icon: "FileCode2",
};
---

<Layout
    title={`${toolMeta.name} | Premium Tools by Axiora`}
    description={toolMeta.desc}
>
    <div class="container mx-auto px-4 py-8 md:py-16">
        {/* SaaS Back Button */}
        <div class="max-w-7xl mx-auto mb-12">
            <a
                href="/"
                class="inline-flex items-center gap-3 text-foreground/50 hover:text-primary font-semibold text-sm tracking-wide transition-all group w-fit outline-none focus-visible:ring-4 focus-visible:ring-primary/30 rounded-full pr-6 bg-white/50 backdrop-blur-md border border-white saas-shadow hover:saas-shadow-hover"
            >
                <div
                    class="w-10 h-10 bg-white rounded-full flex items-center justify-center saas-shadow group-hover:bg-primary/5 transition-colors"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="group-hover:-translate-x-1 transition-transform duration-300"
                    >
                        <path d="m15 18-6-6 6-6"></path>
                    </svg>
                </div>
                Back to Directory
            </a>
        </div>

        {/* The React Component */}
        <Base64ConverterComponent client:only="react" />

        {/* Premium SEO / Context Block */}
        <article
            class="max-w-7xl mx-auto mt-24 flex flex-col gap-12 glass-card rounded-[2.5rem] p-8 sm:p-10 md:p-16 relative overflow-hidden bg-white"
        >
            <div
                class="absolute -top-32 -left-32 w-96 h-96 bg-primary/5 blur-3xl rounded-full pointer-events-none transform-gpu"
            >
            </div>

            <div class="space-y-4 relative z-10 max-w-4xl">
                <h2
                    class="text-3xl md:text-4xl font-extrabold tracking-tight text-foreground"
                >
                    The logic behind <span class="text-gradient">Base64.</span>
                </h2>
                <p
                    class="text-base md:text-lg text-foreground/60 leading-relaxed font-medium"
                >
                    Base64 is a binary-to-text encoding scheme that represents
                    binary data in an ASCII string format. It translates data
                    into a radix-64 representation. This tool runs entirely in
                    your browser's memory, ensuring your payloads are never
                    exposed to external servers.
                </p>
            </div>

            <div
                class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 relative z-10 mt-2"
            >
                {/* Info Card 1 */}
                <div
                    class="flex flex-col gap-4 bg-background/50 rounded-[1.5rem] p-6 md:p-8 border border-border/50 hover:border-primary/20 transition-colors group"
                >
                    <div
                        class="w-12 h-12 bg-white rounded-xl flex items-center justify-center text-primary font-extrabold text-xl saas-shadow mb-2 group-hover:scale-110 transition-transform"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
                            ></path><polyline points="17 8 12 3 7 8"
                            ></polyline><line x1="12" y1="3" x2="12" y2="15"
                            ></line></svg
                        >
                    </div>
                    <h3
                        class="text-xl font-bold text-foreground tracking-tight"
                    >
                        Common Use Cases
                    </h3>
                    <ul
                        class="text-sm md:text-base text-foreground/60 font-medium leading-relaxed space-y-3 mt-2 list-disc pl-5"
                    >
                        <li>
                            <strong>Data URIs:</strong> Embedding small images or
                            fonts directly into CSS/HTML files to save HTTP requests.
                        </li>
                        <li>
                            <strong>Basic Authentication:</strong> Formatting username
                            and password credentials for HTTP headers.
                        </li>
                        <li>
                            <strong>JSON Web Tokens (JWT):</strong> Encoding the header
                            and payload sections of secure tokens.
                        </li>
                    </ul>
                </div>

                {/* Info Card 2 */}
                <div
                    class="flex flex-col gap-4 bg-background/50 rounded-[1.5rem] p-6 md:p-8 border border-border/50 hover:border-secondary/20 transition-colors group"
                >
                    <div
                        class="w-12 h-12 bg-white rounded-xl flex items-center justify-center text-secondary font-extrabold text-xl saas-shadow mb-2 group-hover:scale-110 transition-transform"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                            ></path></svg
                        >
                    </div>
                    <h3
                        class="text-xl font-bold text-foreground tracking-tight"
                    >
                        UTF-8 Safety
                    </h3>
                    <p
                        class="text-sm md:text-base text-foreground/60 font-medium leading-relaxed"
                    >
                        Standard browser <code>btoa()</code> and <code
                            >atob()</code
                        > functions often fail when attempting to process emojis,
                        special characters, or multi-byte Unicode strings. Our Axiora
                        tool is pre-configured with UTF-8 escape logic, ensuring flawless
                        encoding and decoding of any global language string.
                    </p>
                </div>
            </div>
        </article>
    </div>
</Layout>
