---
import Layout from "@/layouts/Layout.astro";
import JsonFormatterComponent from "@/components/tools/JsonFormatter.tsx";

// MAGIC: Automatically adds this to the homepage directory
export const toolMeta = {
    id: "json-fmt",
    name: "JSON Formatter",
    desc: "Instantly beautify, validate, and minify your raw JSON data securely.",
    category: "Developer",
    icon: "Code",
};
---

<Layout
    title={`${toolMeta.name} | Premium Tools by Axiora`}
    description={toolMeta.desc}
>
    <div class="container mx-auto px-4 py-8 md:py-16">
        {/* SaaS Back Button */}
        <div class="max-w-7xl mx-auto mb-12">
            <a
                href="/"
                class="inline-flex items-center gap-3 text-foreground/50 hover:text-primary font-semibold text-sm tracking-wide transition-all group w-fit outline-none focus-visible:ring-4 focus-visible:ring-primary/30 rounded-full pr-6 bg-white/50 backdrop-blur-md border border-white saas-shadow hover:saas-shadow-hover"
            >
                <div
                    class="w-10 h-10 bg-white rounded-full flex items-center justify-center saas-shadow group-hover:bg-primary/5 transition-colors"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="group-hover:-translate-x-1 transition-transform duration-300"
                    >
                        <path d="m15 18-6-6 6-6"></path>
                    </svg>
                </div>
                Back to Directory
            </a>
        </div>

        {/* The React Component */}
        <JsonFormatterComponent client:only="react" />

        {/* Premium SEO / Context Block */}
        <article
            class="max-w-7xl mx-auto mt-24 flex flex-col gap-12 glass-card rounded-[2.5rem] p-10 md:p-16 relative overflow-hidden"
        >
            <div
                class="absolute -top-32 -left-32 w-96 h-96 bg-primary/5 blur-3xl rounded-full pointer-events-none"
            >
            </div>

            <div class="space-y-4 relative z-10 max-w-4xl">
                <h2
                    class="text-3xl md:text-4xl font-extrabold tracking-tight text-foreground"
                >
                    Secure parsing at <span class="text-gradient"
                        >the edge.</span
                    >
                </h2>
                <p
                    class="text-lg text-foreground/60 leading-relaxed font-medium"
                >
                    This utility processes raw, unformatted JSON (JavaScript
                    Object Notation) payloads using your device's native V8
                    JavaScript engine. If the syntax is valid, it restructures
                    the data with proper indentation (pretty printing). If
                    invalid, it traps the error securely without crashing.
                </p>
            </div>

            <div
                class="grid grid-cols-1 md:grid-cols-2 gap-8 relative z-10 mt-4"
            >
                {/* Info Card 1 */}
                <div
                    class="flex flex-col gap-4 bg-background/50 rounded-[1.5rem] p-8 border border-border/50 hover:border-primary/20 transition-colors group"
                >
                    <div
                        class="w-12 h-12 bg-white rounded-xl flex items-center justify-center text-primary font-extrabold text-xl saas-shadow mb-2 group-hover:scale-110 transition-transform"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                            ></path></svg
                        >
                    </div>
                    <h3
                        class="text-xl font-bold text-foreground tracking-tight"
                    >
                        Zero-Trust Security
                    </h3>
                    <p
                        class="text-base text-foreground/60 font-medium leading-relaxed mb-4"
                    >
                        Developers frequently work with highly sensitive API
                        keys, JWT tokens, and user PII embedded within JSON.
                        Axiora Tools processes 100% of the payload directly
                        inside your browser. Your data is never POSTed to an
                        external server, ensuring absolute compliance with
                        security protocols.
                    </p>
                </div>

                {/* Info Card 2 */}
                <div
                    class="flex flex-col gap-4 bg-background/50 rounded-[1.5rem] p-8 border border-border/50 hover:border-secondary/20 transition-colors group"
                >
                    <div
                        class="w-12 h-12 bg-white rounded-xl flex items-center justify-center text-secondary font-extrabold text-xl saas-shadow mb-2 group-hover:scale-110 transition-transform"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"
                            ></path><polyline
                                points="3.27 6.96 12 12.01 20.73 6.96"
                            ></polyline><line x1="12" y1="22.08" x2="12" y2="12"
                            ></line></svg
                        >
                    </div>
                    <h3
                        class="text-xl font-bold text-foreground tracking-tight"
                    >
                        Production Minification
                    </h3>
                    <p
                        class="text-base text-foreground/60 font-medium leading-relaxed mb-4"
                    >
                        Need to reduce payload size before deployment? The
                        "Minify" function leverages regex to strip all
                        unnecessary whitespace, line breaks, and formatting
                        characters—compressing your JSON architecture for
                        high-performance production environments.
                    </p>
                </div>
            </div>
        </article>
    </div>
</Layout>
