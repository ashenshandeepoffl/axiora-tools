---
import Layout from "@/layouts/Layout.astro";
import PasswordGeneratorComponent from "@/components/tools/PasswordGenerator.tsx";

// MAGIC: Automatically adds this to the homepage directory
export const toolMeta = {
    id: "pwd-gen",
    name: "Password Generator",
    desc: "Instantly generate highly secure, mathematically random passwords directly in your browser.",
    category: "Security",
    icon: "ShieldCheck",
};
---

<Layout
    title={`${toolMeta.name} | Premium Tools by Axiora`}
    description={toolMeta.desc}
>
    <div class="container mx-auto px-4 py-8 md:py-16">
        {/* SaaS Back Button */}
        <div class="max-w-5xl mx-auto mb-12">
            <a
                href="/"
                class="inline-flex items-center gap-3 text-foreground/50 hover:text-primary font-semibold text-sm tracking-wide transition-all group w-fit outline-none focus-visible:ring-4 focus-visible:ring-primary/30 rounded-full pr-6 bg-white/50 backdrop-blur-md border border-white saas-shadow hover:saas-shadow-hover"
            >
                <div
                    class="w-10 h-10 bg-white rounded-full flex items-center justify-center saas-shadow group-hover:bg-primary/5 transition-colors"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="group-hover:-translate-x-1 transition-transform duration-300"
                    >
                        <path d="m15 18-6-6 6-6"></path>
                    </svg>
                </div>
                Back to Directory
            </a>
        </div>

        {/* The React Component */}
        <PasswordGeneratorComponent client:only="react" />

        {/* Premium SEO / Context Block */}
        <article
            class="max-w-5xl mx-auto mt-24 flex flex-col gap-12 glass-card rounded-[2.5rem] p-10 md:p-16 relative overflow-hidden"
        >
            <div
                class="absolute -top-32 -left-32 w-96 h-96 bg-primary/5 blur-3xl rounded-full pointer-events-none"
            >
            </div>

            <div class="space-y-4 relative z-10 max-w-4xl">
                <h2
                    class="text-3xl md:text-4xl font-extrabold tracking-tight text-foreground"
                >
                    Engineered with <span class="text-gradient"
                        >WebCrypto API.</span
                    >
                </h2>
                <p
                    class="text-lg text-foreground/60 leading-relaxed font-medium"
                >
                    Unlike older password tools that rely on predictable
                    mathematics (like <code>Math.random()</code>), Axiora Tools
                    utilizes your browser's native cryptographic engine. This
                    ensures absolute entropy, making your passwords
                    mathematically impossible to predict.
                </p>
            </div>

            <div
                class="grid grid-cols-1 md:grid-cols-2 gap-8 relative z-10 mt-4"
            >
                {/* Info Card 1 */}
                <div
                    class="flex flex-col gap-4 bg-background/50 rounded-[1.5rem] p-8 border border-border/50 hover:border-primary/20 transition-colors group"
                >
                    <div
                        class="w-12 h-12 bg-white rounded-xl flex items-center justify-center text-primary font-extrabold text-xl saas-shadow mb-2 group-hover:scale-110 transition-transform"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                            ></path></svg
                        >
                    </div>
                    <h3
                        class="text-xl font-bold text-foreground tracking-tight"
                    >
                        100% Client-Side Privacy
                    </h3>
                    <p
                        class="text-base text-foreground/60 font-medium leading-relaxed mb-4"
                    >
                        We operate on a zero-knowledge architecture. We have no
                        backend database for this tool. Password generation
                        happens entirely within the memory of your current
                        device. It is never transmitted across the internet,
                        ensuring zero risk of network interception.
                    </p>
                </div>

                {/* Info Card 2 */}
                <div
                    class="flex flex-col gap-4 bg-background/50 rounded-[1.5rem] p-8 border border-border/50 hover:border-secondary/20 transition-colors group"
                >
                    <div
                        class="w-12 h-12 bg-white rounded-xl flex items-center justify-center text-secondary font-extrabold text-xl saas-shadow mb-2 group-hover:scale-110 transition-transform"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path d="M2 12h20"></path><path d="M12 2v20"
                            ></path><path d="m4.9 4.9 14.2 14.2"></path><path
                                d="m4.9 19.1 14.2-14.2"></path></svg
                        >
                    </div>
                    <h3
                        class="text-xl font-bold text-foreground tracking-tight"
                    >
                        Modern Entropy Standards
                    </h3>
                    <p
                        class="text-base text-foreground/60 font-medium leading-relaxed mb-4"
                    >
                        With the rise of automated brute-force cloud computing,
                        an 8-character password can be cracked instantly. Modern
                        security standards mandate a minimum of 16 characters.
                        Our generator defaults to high-entropy lengths to secure
                        your digital identity.
                    </p>
                </div>
            </div>
        </article>
    </div>
</Layout>
