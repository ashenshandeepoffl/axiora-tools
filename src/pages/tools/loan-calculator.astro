---
import Layout from "@/layouts/Layout.astro";
import LoanCalculatorComponent from "@/components/tools/LoanCalculator.tsx";

// MAGIC: Automatically adds this to the homepage directory
export const toolMeta = {
    id: "loan-calc",
    name: "Loan Calculator",
    desc: "Estimate monthly payments, total interest, and amortization for mortgages, cars, or personal loans.",
    category: "Finance",
    icon: "Landmark",
};
---

<Layout
    title={`${toolMeta.name} | Premium Tools by Axiora`}
    description={toolMeta.desc}
>
    <div class="container mx-auto px-4 py-8 md:py-16">
        {/* SaaS Back Button */}
        <div class="max-w-5xl mx-auto mb-12">
            <a
                href="/"
                class="inline-flex items-center gap-3 text-foreground/50 hover:text-primary font-semibold text-sm tracking-wide transition-all group w-fit outline-none focus-visible:ring-4 focus-visible:ring-primary/30 rounded-full pr-6 bg-white/50 backdrop-blur-md border border-white saas-shadow hover:saas-shadow-hover"
            >
                <div
                    class="w-10 h-10 bg-white rounded-full flex items-center justify-center saas-shadow group-hover:bg-primary/5 transition-colors"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="group-hover:-translate-x-1 transition-transform duration-300"
                    >
                        <path d="m15 18-6-6 6-6"></path>
                    </svg>
                </div>
                Back to Directory
            </a>
        </div>

        {/* The React Component */}
        <LoanCalculatorComponent client:only="react" />

        {/* Premium SEO / Context Block */}
        <article
            class="max-w-5xl mx-auto mt-24 flex flex-col gap-12 glass-card rounded-[2.5rem] p-8 sm:p-10 md:p-16 relative overflow-hidden bg-white"
        >
            <div
                class="absolute -top-32 -left-32 w-96 h-96 bg-primary/5 blur-3xl rounded-full pointer-events-none transform-gpu"
            >
            </div>

            <div class="space-y-4 relative z-10 max-w-3xl">
                <h2
                    class="text-3xl md:text-4xl font-extrabold tracking-tight text-foreground"
                >
                    Demystifying <span class="text-gradient">Amortization.</span
                    >
                </h2>
                <p
                    class="text-base md:text-lg text-foreground/60 leading-relaxed font-medium"
                >
                    Understanding the true cost of borrowing money is crucial
                    for financial health. This calculator uses the standard
                    Equated Monthly Installment (EMI) formula used by banks and
                    lending institutions globally to calculate exact repayment
                    schedules.
                </p>
            </div>

            <div
                class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 relative z-10 mt-2"
            >
                {/* Info Card 1 */}
                <div
                    class="flex flex-col gap-4 bg-background/50 rounded-[1.5rem] p-6 md:p-8 border border-border/50 hover:border-primary/20 transition-colors group"
                >
                    <div
                        class="w-12 h-12 bg-white rounded-xl flex items-center justify-center text-primary font-extrabold text-xl saas-shadow mb-2 group-hover:scale-110 transition-transform"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path d="M2 12h20"></path><path d="M12 2v20"
                            ></path><path d="m4.9 4.9 14.2 14.2"></path><path
                                d="m4.9 19.1 14.2-14.2"></path></svg
                        >
                    </div>
                    <h3
                        class="text-xl font-bold text-foreground tracking-tight"
                    >
                        How is Interest Calculated?
                    </h3>
                    <p
                        class="text-sm md:text-base text-foreground/60 font-medium leading-relaxed"
                    >
                        Most standard loans use compound interest calculated
                        monthly. At the beginning of your loan, a massive
                        portion of your monthly payment goes toward paying off
                        the interest, with very little going toward the actual
                        principal. Over time, this ratio flips.
                    </p>
                </div>

                {/* Info Card 2 */}
                <div
                    class="flex flex-col gap-4 bg-background/50 rounded-[1.5rem] p-6 md:p-8 border border-border/50 hover:border-secondary/20 transition-colors group"
                >
                    <div
                        class="w-12 h-12 bg-white rounded-xl flex items-center justify-center text-secondary font-extrabold text-xl saas-shadow mb-2 group-hover:scale-110 transition-transform"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><line x1="12" x2="12" y1="20" y2="10"></line><line
                                x1="18"
                                x2="18"
                                y1="20"
                                y2="4"></line><line
                                x1="6"
                                x2="6"
                                y1="20"
                                y2="16"></line></svg
                        >
                    </div>
                    <h3
                        class="text-xl font-bold text-foreground tracking-tight"
                    >
                        The Impact of Time
                    </h3>
                    <p
                        class="text-sm md:text-base text-foreground/60 font-medium leading-relaxed"
                    >
                        Extending the term of a loan (e.g., choosing a 6-year
                        car loan instead of a 3-year loan) will dramatically
                        lower your monthly payment. However, as the calculator
                        shows, it significantly increases the <strong
                            >Total Interest</strong
                        > you will pay over the life of the loan.
                    </p>
                </div>
            </div>
        </article>
    </div>
</Layout>
