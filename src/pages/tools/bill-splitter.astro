---
import Layout from "@/layouts/Layout.astro";
import BillSplitterComponent from "@/components/tools/BillSplitter.tsx";

// MAGIC: Automatically adds this to the homepage directory
export const toolMeta = {
    id: "bill-split",
    name: "Bill Splitter",
    desc: "Easily calculate tips and divide expenses among friends with our fintech-grade calculator.",
    category: "Finance",
    icon: "Receipt",
};
---

<Layout
    title={`${toolMeta.name} | Premium Tools by Axiora`}
    description={toolMeta.desc}
>
    <div class="container mx-auto px-4 py-8 md:py-16">
        {/* SaaS Back Button */}
        <div class="max-w-6xl mx-auto mb-12">
            <a
                href="/"
                class="inline-flex items-center gap-3 text-foreground/50 hover:text-primary font-semibold text-sm tracking-wide transition-all group w-fit outline-none focus-visible:ring-4 focus-visible:ring-primary/30 rounded-full pr-6 bg-white/50 backdrop-blur-md border border-white saas-shadow hover:saas-shadow-hover"
            >
                <div
                    class="w-10 h-10 bg-white rounded-full flex items-center justify-center saas-shadow group-hover:bg-primary/5 transition-colors"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="group-hover:-translate-x-1 transition-transform duration-300"
                    >
                        <path d="m15 18-6-6 6-6"></path>
                    </svg>
                </div>
                Back to Directory
            </a>
        </div>

        {/* The React Component */}
        <BillSplitterComponent client:only="react" />

        {/* Premium SEO / Context Block */}
        <article
            class="max-w-6xl mx-auto mt-24 flex flex-col gap-12 glass-card rounded-[2.5rem] p-8 sm:p-10 md:p-16 relative overflow-hidden bg-white"
        >
            <div
                class="absolute -top-32 -left-32 w-96 h-96 bg-primary/5 blur-3xl rounded-full pointer-events-none transform-gpu"
            >
            </div>

            <div class="space-y-4 relative z-10 max-w-4xl">
                <h2
                    class="text-3xl md:text-4xl font-extrabold tracking-tight text-foreground"
                >
                    Fair maths for <span class="text-gradient"
                        >everyday expenses.</span
                    >
                </h2>
                <p
                    class="text-base md:text-lg text-foreground/60 leading-relaxed font-medium"
                >
                    Whether you are dining out with friends or splitting
                    household bills, doing mental math at the table can be
                    stressful. This tool uses JavaScript's high-precision float
                    calculation to ensure every penny is accounted for and
                    divided equally.
                </p>
            </div>

            <div
                class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 relative z-10 mt-2"
            >
                {/* Info Card 1 */}
                <div
                    class="flex flex-col gap-4 bg-background/50 rounded-[1.5rem] p-6 md:p-8 border border-border/50 hover:border-primary/20 transition-colors group"
                >
                    <div
                        class="w-12 h-12 bg-white rounded-xl flex items-center justify-center text-primary font-extrabold text-xl saas-shadow mb-2 group-hover:scale-110 transition-transform"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path d="M12 2v20"></path><path
                                d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"
                            ></path></svg
                        >
                    </div>
                    <h3
                        class="text-xl font-bold text-foreground tracking-tight"
                    >
                        Tipping Standards
                    </h3>
                    <p
                        class="text-sm md:text-base text-foreground/60 font-medium leading-relaxed"
                    >
                        In many regions, particularly North America, a <strong
                            >15% to 20%</strong
                        > tip is standard for restaurant services. The 18% option
                        is widely considered the sweet spot for good service, while
                        20% or higher is reserved for excellent experiences.
                    </p>
                </div>

                {/* Info Card 2 */}
                <div
                    class="flex flex-col gap-4 bg-background/50 rounded-[1.5rem] p-6 md:p-8 border border-border/50 hover:border-secondary/20 transition-colors group"
                >
                    <div
                        class="w-12 h-12 bg-white rounded-xl flex items-center justify-center text-secondary font-extrabold text-xl saas-shadow mb-2 group-hover:scale-110 transition-transform"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"
                            ></path><circle cx="9" cy="7" r="4"></circle><path
                                d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path
                                d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg
                        >
                    </div>
                    <h3
                        class="text-xl font-bold text-foreground tracking-tight"
                    >
                        Splitting Etiquette
                    </h3>
                    <p
                        class="text-sm md:text-base text-foreground/60 font-medium leading-relaxed"
                    >
                        When dining in large groups, an equal split (where the
                        total bill + tip is divided evenly by the number of
                        people) is the fastest and most socially accepted
                        method, assuming everyone ordered items of relatively
                        similar value.
                    </p>
                </div>
            </div>
        </article>
    </div>
</Layout>
